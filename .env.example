# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                        MULTI-MCP AGENT CONFIGURATION                        ║
# ╚══════════════════════════════════════════════════════════════════════════════╝
#
# Copia questo file in .env e compila i valori.
# Provider e API key sono configurati UNA SOLA VOLTA nella sezione MAIN AGENT.
# I sotto-agenti ereditano provider e credenziali dall'orchestratore quando
# vengono chiamati tramite main_agent.py.
#
# Per usare un sotto-agente in modalità standalone (senza main_agent.py),
# decommenta e compila le variabili provider nella sua sezione.
#
# Provider supportati: openrouter | groq | gemini | cloudflare | cerebras | mistral | puter | ollama


# ══════════════════════════════════════════════════════════════════════════════
#  MAIN AGENT  —  orchestratore multi-dominio  (main_agent.py)
#  Configura qui il provider: vale per l'orchestratore E per tutti i sotto-agenti.
# ══════════════════════════════════════════════════════════════════════════════

MAIN_AGENT_PROVIDER=rotate           # vuoto o "rotate" = rotazione automatica tra provider con API key
# MAIN_AGENT_MODEL=                  # forza un modello specifico (ignorato in modalità rotazione)
MAIN_AGENT_VERBOSE=true              # true = mostra provider/modello usato ad ogni chiamata LLM
# MAIN_AGENT_ROTATE_KEYS=            # slot key da usare (es: "1" = solo primary, "1,3" = slot 1 e 3)
                                     # vuoto = usa tutte le key configurate

# ─── OpenRouter ───────────────────────────────────────────────────────────────
# Più key: MAIN_AGENT_OPENROUTER_API_KEY_2=sk-or-...  _3=sk-or-...  ecc.
MAIN_AGENT_OPENROUTER_API_KEY=sk-or-v1-...
# MAIN_AGENT_OPENROUTER_API_KEY_2=sk-or-v1-...
# MAIN_AGENT_OPENROUTER_MODEL=openrouter/auto

# ─── Groq ─────────────────────────────────────────────────────────────────────
# Più key: MAIN_AGENT_GROQ_API_KEY_2=gsk_...  _3=gsk_...  ecc.
MAIN_AGENT_GROQ_API_KEY=gsk_...
# MAIN_AGENT_GROQ_API_KEY_2=gsk_...
# MAIN_AGENT_GROQ_MODEL=llama-3.3-70b-versatile

# ─── Google Gemini ────────────────────────────────────────────────────────────
# Più key: MAIN_AGENT_GEMINI_API_KEY_2=AIza...  _3=AIza...  ecc.
MAIN_AGENT_GEMINI_API_KEY=AIza...
# MAIN_AGENT_GEMINI_MODEL=gemini-2.0-flash

# ─── Cloudflare Workers AI ────────────────────────────────────────────────────
# Account aggiuntivi: ogni coppia KEY+ACCOUNT_ID deve avere lo stesso suffisso _N
MAIN_AGENT_CLOUDFLARE_API_KEY=cfut_...
MAIN_AGENT_CLOUDFLARE_ACCOUNT_ID=your_account_id
# MAIN_AGENT_CLOUDFLARE_API_KEY_2=cfut_...
# MAIN_AGENT_CLOUDFLARE_ACCOUNT_ID_2=your_account_id_2
# MAIN_AGENT_CLOUDFLARE_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast

# ─── Cerebras ─────────────────────────────────────────────────────────────────
# Più key: MAIN_AGENT_CEREBRAS_API_KEY_2=csk-...  ecc.
MAIN_AGENT_CEREBRAS_API_KEY=csk-...
# MAIN_AGENT_CEREBRAS_API_KEY_2=csk-...
# MAIN_AGENT_CEREBRAS_MODEL=llama-3.3-70b

# ─── Mistral ──────────────────────────────────────────────────────────────────
# Più key: MAIN_AGENT_MISTRAL_API_KEY_2=...  ecc.
MAIN_AGENT_MISTRAL_API_KEY=...
# MAIN_AGENT_MISTRAL_API_KEY_2=...
# MAIN_AGENT_MISTRAL_MODEL=mistral-small-latest

# ─── Puter ────────────────────────────────────────────────────────────────────
# Puter.com offre inferenza gratuita senza API key obbligatoria.
# Imposta un valore qualsiasi (es. "nokey") per includerlo nella rotazione.
# Più key: MAIN_AGENT_PUTER_API_KEY_2=...  ecc.
MAIN_AGENT_PUTER_API_KEY=nokey
# MAIN_AGENT_PUTER_API_KEY_2=nokey
# MAIN_AGENT_PUTER_MODEL=gpt-4o-mini

# ─── Ollama ───────────────────────────────────────────────────────────────────
MAIN_AGENT_OLLAMA_HOST=http://localhost:11434
# MAIN_AGENT_OLLAMA_MODEL=llama3.2:1b


# ══════════════════════════════════════════════════════════════════════════════
#  LINUX SSH SERVERS  (credenziali SSH — usate da linux_mcp_agent.py)
#  Il loader si ferma al primo N mancante: la numerazione deve essere continua.
# ══════════════════════════════════════════════════════════════════════════════

UXMCP_SERVER_1_LABEL=server1
UXMCP_SERVER_1_HOST=192.168.0.x
UXMCP_SERVER_1_PORT=22
UXMCP_SERVER_1_USER=admin
UXMCP_SERVER_1_PASSWORD=your_password
# UXMCP_SERVER_1_SUDO_PASSWORD=your_sudo_password
# UXMCP_SERVER_1_KEY_PATH=~/.ssh/id_rsa

# Template per server aggiuntivi:
# UXMCP_SERVER_2_LABEL=server2
# UXMCP_SERVER_2_HOST=192.168.0.y
# UXMCP_SERVER_2_PORT=22
# UXMCP_SERVER_2_USER=root
# UXMCP_SERVER_2_PASSWORD=your_password


# ══════════════════════════════════════════════════════════════════════════════
#  LINUX SSH AGENT  (linux_mcp_agent.py)
# ══════════════════════════════════════════════════════════════════════════════

UXMCP_MCP_DOCKER_IMAGE=lordraw/linux-mcp:latest
# UXMCP_MCP_SSH_KEY_DIR=~/.ssh

# Standalone mode — decommenta per usare linux_mcp_agent.py senza main_agent.py:
# UXMCP_AGENT_PROVIDER=openrouter
# UXMCP_AGENT_MODEL=


# ══════════════════════════════════════════════════════════════════════════════
#  SYNOLOGY NAS AGENT  (synology_mcp_agent.py)
# ══════════════════════════════════════════════════════════════════════════════

# ─── Connessione NAS ──────────────────────────────────────────────────────────
SYNOLOGY_MCP_NAS_CONFIG=nas_config.json

# Fallback single-NAS (solo se SYNOLOGY_MCP_NAS_CONFIG non è impostato):
# SYNOLOGY_MCP_HOST=192.168.0.x
# SYNOLOGY_MCP_PORT=5000
# SYNOLOGY_MCP_HTTPS=false
# SYNOLOGY_MCP_VERIFY_SSL=false
# SYNOLOGY_MCP_USER=admin
# SYNOLOGY_MCP_PASSWORD=your_password

SYNOLOGY_MCP_DOCKER_IMAGE=lordraw/synology-mcp:latest

# Standalone mode — decommenta per usare synology_mcp_agent.py senza main_agent.py:
# SYNOLOGY_MCP_AI_PROVIDER=openrouter
# SYNOLOGY_MCP_AI_MODEL=


# ══════════════════════════════════════════════════════════════════════════════
#  PROXMOX AGENT  (proxmox_mcp_agent.py)
# ══════════════════════════════════════════════════════════════════════════════

# ─── Connessione Proxmox ──────────────────────────────────────────────────────
PROXMOX_MCP_HOST=192.168.0.x
PROXMOX_MCP_PORT=8006
PROXMOX_MCP_USER=root@pam
PROXMOX_MCP_PASSWORD=your_password
PROXMOX_MCP_VERIFY_SSL=false
# PROXMOX_MCP_TOKEN_ID=mytoken
# PROXMOX_MCP_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

PROXMOX_MCP_DOCKER_IMAGE=lordraw/proxmox-mcp:latest

# Standalone mode — decommenta per usare proxmox_mcp_agent.py senza main_agent.py:
# PROXMOX_MCP_PROVIDER=openrouter
# PROXMOX_MCP_MODEL=


# ══════════════════════════════════════════════════════════════════════════════
#  HOME ASSISTANT AGENT  (homeassistant_mcp_agent.py)
# ══════════════════════════════════════════════════════════════════════════════

# ─── Connessione Home Assistant ───────────────────────────────────────────────
HAOS_MCP_URL=http://192.168.0.x:8123
HAOS_MCP_TOKEN=your_long_lived_access_token

# Provider e API key ereditati automaticamente da MAIN_AGENT_* — non serve duplicarli.
# Standalone mode — decommenta per usare homeassistant_mcp_agent.py senza main_agent.py:
# HAOS_MCP_PROVIDER=openrouter


# ══════════════════════════════════════════════════════════════════════════════
#  WATCHYOURLAN AGENT  (watchyourlan_mcp_agent.py)
# ══════════════════════════════════════════════════════════════════════════════

# ─── Connessione WatchYourLAN ─────────────────────────────────────────────────
# WYL_BASE_URL è il nome della variabile usata dal container lordraw/watchyourlan-mcp
WYLA_MCP_URL=http://192.168.0.x:8840
# WYLA_MCP_TIMEOUT=10                  # timeout HTTP in secondi (default: 10)

WYLA_MCP_DOCKER_IMAGE=lordraw/watchyourlan-mcp:latest

# Provider e API key ereditati automaticamente da MAIN_AGENT_* — non serve duplicarli.
# Standalone mode — decommenta per usare watchyourlan_mcp_agent.py senza main_agent.py:
# WYLA_MCP_PROVIDER=openrouter
